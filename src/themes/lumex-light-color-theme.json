    "focusBorder": "#6D5CEC",
    "foreground": "#1E293B",
    "disabledForeground": "#CBD5E1",
    "descriptionForeground": "#64748B",
    "errorForeground": "#DC2626",
    "textLink.foreground": "#6D5CEC",
    "textLink.activeForeground": "#0EA5E9",
    "textBlockQuote.background": "#F1F5F9",
    "textBlockQuote.border": "#6D5CEC",
    "textCodeBlock.background": "#F1F5F9"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#94A3B8", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#16A34A" } },
    { "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#0891B2" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#D97706" } },
    { "scope": ["constant.language"], "settings": { "foreground": "#6D5CEC", "fontStyle": "italic" } },
    { "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"], "settings": { "foreground": "#DB2777" } },
    { "scope": ["keyword.operator", "punctuation.separator"], "settings": { "foreground": "#64748B" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#2563EB" } },
    { "scope": ["entity.name.class", "entity.name.type", "support.class"], "settings": { "foreground": "#D97706" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#0891B2", "fontStyle": "italic" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#1E293B" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#1E293B", "fontStyle": "italic" } },
    { "scope": ["meta.decorator"], "settings": { "foreground": "#0891B2", "fontStyle": "italic" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#DB2777" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#D97706" } },
    { "scope": ["support.type.property-name.json"], "settings": { "foreground": "#2563EB" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#6D5CEC", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "foreground": "#D97706", "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "foreground": "#DB2777", "fontStyle": "italic" } },
    { "scope": ["markup.inline.raw.string.markdown"], "settings": { "foreground": "#0891B2" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#2563EB", "fontStyle": "underline" } }
  ],
  "semanticHighlighting": true
}
