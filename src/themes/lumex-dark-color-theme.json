  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment", "comment.block", "comment.line"],
      "settings": { "foreground": "#475569", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template", "string.interpolated"],
      "settings": { "foreground": "#4ADE80" }
    },
    {
      "name": "String escape characters",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#3ECFCF" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float", "constant.numeric.hex", "constant.numeric.octal"],
      "settings": { "foreground": "#FBBF24" }
    },
    {
      "name": "Boolean and null",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#7C6AF7" }
    },
    {
      "name": "Language constants",
      "scope": ["constant.language", "support.constant", "variable.language.this", "variable.language.super", "variable.language.self"],
      "settings": { "foreground": "#7C6AF7", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "keyword.operator.new", "keyword.other.using", "keyword.other.operator", "storage.modifier.import", "storage.modifier.package"],
      "settings": { "foreground": "#F472B6" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#94A3B8" }
    },
    {
      "name": "Storage types (var, let, const, class...)",
      "scope": ["storage.type", "storage.modifier", "keyword.declaration"],
      "settings": { "foreground": "#F472B6" }
    },
    {
      "name": "Function definitions",
      "scope": ["entity.name.function", "meta.function entity.name.function", "support.function"],
      "settings": { "foreground": "#60A5FA" }
    },
    {
      "name": "Function calls",
      "scope": ["meta.function-call", "meta.function-call.generic", "entity.name.function.call"],
      "settings": { "foreground": "#60A5FA" }
    },
    {
      "name": "Classes and types",
      "scope": ["entity.name.class", "entity.name.type", "entity.name.type.class", "support.class"],
      "settings": { "foreground": "#FBBF24" }
    },
    {
      "name": "Class constructors",
      "scope": ["entity.name.function.constructor", "entity.name.function.destructor"],
      "settings": { "foreground": "#FBBF24" }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#3ECFCF", "fontStyle": "italic" }
    },
    {
      "name": "Enums",
      "scope": ["entity.name.type.enum"],
      "settings": { "foreground": "#FBBF24" }
    },
    {
      "name": "Type parameters / generics",
      "scope": ["entity.name.type.parameter", "meta.type.parameters"],
      "settings": { "foreground": "#3ECFCF" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": { "foreground": "#E2E8F0" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.parameters variable.other"],
      "settings": { "foreground": "#E2E8F0", "fontStyle": "italic" }
    },
    {
      "name": "Object properties",
      "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"],
      "settings": { "foreground": "#E2E8F0" }
    },
    {
      "name": "Decorators / annotations",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#3ECFCF", "fontStyle": "italic" }
    },
    {
      "name": "Import / module paths",
      "scope": ["entity.name.module", "meta.import string", "string.quoted.single.import"],
      "settings": { "foreground": "#4ADE80" }
    },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#F472B6" }
    },
    {
      "name": "HTML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#FBBF24" }
    },
    {
      "name": "HTML Attribute values",
      "scope": ["meta.attribute-with-value string"],
      "settings": { "foreground": "#4ADE80" }
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css", "entity.name.tag.css"],
      "settings": { "foreground": "#FBBF24" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#60A5FA" }
    },
    {
      "name": "CSS values",
      "scope": ["support.constant.property-value.css", "meta.property-value.css"],
      "settings": { "foreground": "#4ADE80" }
    },
    {
      "name": "CSS units",
      "scope": ["keyword.other.unit.css", "constant.numeric.css"],
      "settings": { "foreground": "#FBBF24" }
    },
    {
      "name": "CSS pseudo-classes and elements",
      "scope": ["entity.other.attribute-name.pseudo-class.css", "entity.other.attribute-name.pseudo-element.css"],
      "settings": { "foreground": "#3ECFCF" }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json", "meta.object-literal.key string"],
      "settings": { "foreground": "#60A5FA" }
    },
    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml", "meta.tag.yaml"],
      "settings": { "foreground": "#60A5FA" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#7C6AF7", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#FBBF24", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#F472B6", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw.string.markdown"],
      "settings": { "foreground": "#3ECFCF" }
    },
    {
      "name": "Markdown code block",
      "scope": ["markup.fenced_code.block.markdown"],
      "settings": { "foreground": "#E2E8F0" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link", "markup.underline.link.image"],
      "settings": { "foreground": "#60A5FA", "fontStyle": "underline" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#94A3B8", "fontStyle": "italic" }
    },
    {
      "name": "Punctuation brackets",
      "scope": ["punctuation.definition.tag", "meta.brace", "punctuation.definition.block"],
      "settings": { "foreground": "#94A3B8" }
    },
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid", "invalid.illegal", "invalid.deprecated"],
      "settings": { "foreground": "#F87171", "fontStyle": "strikethrough" }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#4ADE80" }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#F87171" }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#FBBF24" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#3ECFCF",
    "type": "#FBBF24",
